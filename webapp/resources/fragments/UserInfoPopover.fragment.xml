<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core">
    <ResponsivePopover
        id="userInfoPopover"
        showHeader="false"
        contentWidth="300px"
        placement="Bottom">
        <content>
            <VBox width="100%" height="100%">
                <HBox alignContent="Center" justifyContent="Center"
                    class="sapUiSmallMarginTop">
                    <Avatar
                        initials="{twoWay>/userInitials}"
                        displaySize="L"
                        showBorder="true"
                        press="onPress">
                        <customData>
                            <core:CustomData
                                key="testId"
                                value="userInfoPopover-avatar"
                                writeToDom="true" />
                        </customData>
                    </Avatar>
                </HBox>
                <HBox justifyContent="Center" alignContent="Center"
                    class="sapUiTinyMarginTop">
                    <Title text="{twoWay>/userName}" level="H3">
                        <customData>
                            <core:CustomData
                                key="testId"
                                value="userInfoPopover-title"
                                writeToDom="true" />
                        </customData>
                    </Title>
                </HBox>
                <HBox justifyContent="Center" alignContent="Center">
                    <Label text="{twoWay>/userEmail}">
                        <customData>
                            <core:CustomData
                                key="testId"
                                value="userInfoPopover-emailLabel"
                                writeToDom="true" />
                        </customData>
                    </Label>
                </HBox>
                <HBox justifyContent="Center" alignContent="Center">
                    <Label text="{twoWay>/userRole}">
                        <customData>
                            <core:CustomData
                                    key="testId"
                                    value="userInfoPopover-userRole"
                                    writeToDom="true" />
                        </customData>
                    </Label>
                </HBox>
                <VBox class="sapUiSmallMarginTop">
                    <Button
                        text="{i18n>settings}"
                        icon="sap-icon://action-settings"
                        type="Transparent"
                        width="100%"
                        press="onOpenSettingsDialog">
                        <customData>
                            <core:CustomData
                                key="testId"
                                value="userInfoPopover-settingsButton"
                                writeToDom="true" />
                        </customData>
                    </Button>
                    <Button
                        text="{i18n>signOut}"
                        icon="sap-icon://log"
                        type="Transparent"
                        width="100%"
                        press="onSignOutPress">
                        <customData>
                            <core:CustomData
                                key="testId"
                                value="userInfoPopover-signOutButton"
                                writeToDom="true" />
                        </customData>
                    </Button>
                </VBox>
            </VBox>
        </content>
    </ResponsivePopover>
</core:FragmentDefinition>