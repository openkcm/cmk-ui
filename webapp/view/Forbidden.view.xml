<mvc:View
    controllerName="kms.controller.Forbidden"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:mvc="sap.ui.core.mvc">
    <f:DynamicPage>
        <f:title>
        </f:title>
        <f:content>
            <VBox alignItems="Center" justifyContent="Center">
                <IllustratedMessage enableVerticalResponsiveness="false"
                    title="{forbidden>/errorTitle}"
                    description="{forbidden>/errorMessage}"
                    enableDefaultTitleAndDescription="false"
                    illustrationType="sapIllus-UnableToLoad"
                    illustrationSize="Scene">
                </IllustratedMessage>
                <Button
                    text="{i18n>retryLogin}"
                    type="Emphasized"
                    press=".onRetryLogin"
                    visible="{forbidden>/loginButtonVisible}"
                    class="sapUiSmallMarginTop" />
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>